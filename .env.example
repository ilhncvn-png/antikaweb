# Değerli Eşya Merkezi — Environment Variables
# Copy to .env.local and fill in real values before deploying

# ── Site ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://degerliesyamerkezi.com

# ── Google Analytics 4 ────────────────────────────
# Get from analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google Ads conversion tracking ───────────────
# Get from Google Ads → Tools → Measurement → Conversion actions
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX

# ── Contact form: email destination ──────────────
CONTACT_EMAIL=info@degerliesyamerkezi.com

# ── Contact form: Resend email API ───────────────
# Sign up at resend.com, verify domain, get API key
# Required to actually send contact form emails to CONTACT_EMAIL
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── IMPORTANT: API route + static export ─────────
# If using `output: 'export'` in next.config.mjs, the /api/contact route
# will NOT be available in the static build. Two options:
#   1. Remove `output: 'export'` and deploy to Vercel / a Node.js host
#   2. Replace the form with a client-side service (Formspree, EmailJS, etc.)
